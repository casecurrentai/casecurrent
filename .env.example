# CaseCurrent Environment Variables
# Copy this file to .env and fill in your values

# Required - PostgreSQL database connection string
DATABASE_URL=postgresql://user:password@host:5432/database

# Optional - Public hostname for webhooks (e.g., casecurrent.co)
PUBLIC_HOST=

# Optional - OpenAI API key for AI voice features
OPENAI_API_KEY=

# Optional - HMAC secret for stream authentication
STREAM_TOKEN_SECRET=

# Optional - Twilio credentials (for voice/SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Optional - Expo token for EAS builds
EXPO_TOKEN=

# Optional - Vapi API key for fetching call artifacts server-side (transcript, recording)
# Get this from https://dashboard.vapi.ai/account/keys — use the private/secret key
VAPI_API_KEY=

# Optional - Artifact cache TTL in hours (default: 6)
VAPI_ARTIFACT_TTL_HOURS=6
